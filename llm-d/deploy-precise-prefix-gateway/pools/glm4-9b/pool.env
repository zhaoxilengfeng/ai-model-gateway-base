# pools/glm4-9b/pool.env — GLM-4-9B 推理池配置
# RENDER_MODEL_PATH: 容器内路径（hostPath MODEL_CACHE 挂载到 /root/models）
# MODEL_CACHE: 宿主机路径（hostPath 来源）

GUIDE_NAME="glm4-9b-pool"
SERVED_MODEL="glm-4-9b"
RENDER_MODEL_PATH="/root/models/glm-4-9b-chat"
MODEL_CACHE="/home/data/model"
NAMESPACE="llm-d-precise-prefix-gw"
TRUST_REMOTE_CODE="--trust-remote-code"
