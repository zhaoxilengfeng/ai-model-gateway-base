load:
  type: constant
  stages:
    - rate: 1
      duration: 30
  request_timeout: 30
  num_workers: 1
api:
  type: completion
  streaming: true
server:
  type: vllm
  model_name: REPLACE_ENV_LLMDBENCH_DEPLOY_CURRENT_MODEL
  base_url: REPLACE_ENV_LLMDBENCH_HARNESS_STACK_ENDPOINT_URL
  ignore_eos: true
tokenizer:
  pretrained_model_name_or_path: /requests/tokenizer
data:
  type: random
  input_distribution:
    min: 256
    max: 512
    mean: 384
    std_dev: 10
    total_count: 100
  output_distribution:
    min: 10
    max: 100
    mean: 50
    std_dev: 10
    total_count: 100
report:
  request_lifecycle:
    summary: true
    per_stage: true
    per_request: true
storage:
  local_storage:
    path: /workspace
