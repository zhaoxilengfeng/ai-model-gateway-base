load:
  type: constant
  stages:
    - rate: 1
      duration: 120
    - rate: 2
      duration: 120
    - rate: 4
      duration: 120
    - rate: 8
      duration: 120
api:
  type: completion
  streaming: true
server:
  type: vllm
  model_name: REPLACE_ENV_LLMDBENCH_DEPLOY_CURRENT_MODEL
  base_url: REPLACE_ENV_LLMDBENCH_HARNESS_STACK_ENDPOINT_URL
  ignore_eos: true
tokenizer:
  pretrained_model_name_or_path: /requests/tokenizer
data:
  type: random
  input_distribution:
    min: 10
    max: 1024
    mean: 512
    std_dev: 256
    total_count: 1000
  output_distribution:
    min: 10
    max: 512
    mean: 256
    std_dev: 128
    total_count: 1000
report:
  request_lifecycle:
    summary: true
    per_stage: true
    per_request: true
storage:
  local_storage:
    path: /workspace
