load:
  type: concurrent
  num_workers: 8
  worker_max_concurrency: 1000
  stages:
  - num_requests: 100
    concurrency_level: 5
  - num_requests: 200
    concurrency_level: 10
  - num_requests: 400
    concurrency_level: 20
  - num_requests: 600
    concurrency_level: 30
  - num_requests: 800
    concurrency_level: 40
api:
  type: chat
  streaming: true
server:
  type: vllm
  model_name: REPLACE_ENV_LLMDBENCH_DEPLOY_CURRENT_MODEL
  base_url: REPLACE_ENV_LLMDBENCH_HARNESS_STACK_ENDPOINT_URL
tokenizer:
  pretrained_model_name_or_path: /requests/tokenizer
data:
  type: conversation_replay
  conversation_replay:
    seed: 42
    max_model_len: 8192     # 适配当前 vLLM max-model-len
    num_conversations: 40
    shared_system_prompt_len: 512
    dynamic_system_prompt_len:
      type: lognormal
      min: 100
      max: 3000
      mean: 800
      std_dev: 600
    turns_per_conversation:
      type: lognormal
      min: 1
      max: 20
      mean: 5
      std_dev: 4
    input_tokens_per_turn:
      type: lognormal
      min: 50
      max: 1000
      mean: 300
      std_dev: 200
    output_tokens_per_turn:
      type: lognormal
      min: 50
      max: 512
      mean: 200
      std_dev: 150
    tool_call_latency_sec:
      type: lognormal
      min: 0
      max: 5
      mean: 1
      std_dev: 1
report:
  request_lifecycle:
    summary: true
    per_stage: true
    per_request: true
storage:
  local_storage:
    path: /workspace
