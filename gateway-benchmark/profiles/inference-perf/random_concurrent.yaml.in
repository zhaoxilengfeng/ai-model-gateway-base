load:
  type: concurrent
  stages:
    # Stage 1: 1 concurrent user, 32 total requests
    - concurrency_level: 1
      num_requests: 32
    # Stage 2: 2 concurrent users, 64 total requests
    - concurrency_level: 2
      num_requests: 64
    # Stage 3: 4 concurrent users, 128 total requests
    - concurrency_level: 4
      num_requests: 128
    # Stage 4: 8 concurrent users, 256 total requests
    - concurrency_level: 8
      num_requests: 256
api:
  type: completion
  streaming: true
server:
  type: vllm
  model_name: REPLACE_ENV_LLMDBENCH_DEPLOY_CURRENT_MODEL
  base_url: REPLACE_ENV_LLMDBENCH_HARNESS_STACK_ENDPOINT_URL
  ignore_eos: true
tokenizer:
  pretrained_model_name_or_path: /requests/tokenizer
data:
  type: random
  input_distribution:
    min: 256
    max: 6144           # 适配 max-model-len=8192，留 2048 给输出
    mean: 2048
    std: 1024
  output_distribution:
    min: 128
    max: 512
    mean: 256
    std: 128
report:
  request_lifecycle:
    summary: true
    per_stage: true
    per_request: true
storage:
  local_storage:
    path: /workspace
